# [ToxicTracker] Professional .gitignore
# Purpose: Exclude unnecessary files from source control to maintain a clean and efficient development environment.

# Node.js / Frontend
node_modules/
dist/
build/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Java / Spring Boot (Maven)
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# IDEs & System
.vscode/
.idea/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
.DS_Store
Thumbs.db
desktop.ini

# Environment / Secret Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# Database
*.db
*.sqlite
