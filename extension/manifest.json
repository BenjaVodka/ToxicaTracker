{
  "manifest_version": 3,
  "name": "ToxicTracker Pro",
  "version": "1.0",
  "description": "Extractor local ultra-rápido de seguidores.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "https://*.vercel.app/*"],
      "js": ["inject.js"],
      "run_at": "document_idle"
    }
  ]
}
